{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter grapesjs-cli build && pnpm --filter grapesjs build && cp packages/core/dist/grapes.min.js packages/core/grapes.min.js",
  "outputDirectory": "packages/core",
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/send-test-email",
      "dest": "/api/send-test-email"
    },
    {
      "src": "/email-api/health",
      "dest": "/api/health"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
